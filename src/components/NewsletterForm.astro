---
interface Props {
  lang?: string;
}
const { lang = 'en' } = Astro.props;
const isEN = lang === 'en';
---

<section id="newsletter" class="my-20">
  <div class="max-w-2xl mx-auto px-4 text-center">
    <div class="card p-10">
      <span class="text-4xl mb-4 block">📬</span>
      <h2 class="text-2xl font-bold text-white mb-2">
        {isEN ? 'Get the Best AI Tools Every Week' : 'As Melhores Ferramentas de IA toda semana'}
      </h2>
      <p class="text-gray-400 mb-6 text-sm">
        {isEN
          ? 'Join 2,000+ readers. Every Tuesday: top AI tool reviews, deals & tutorials. Free forever.'
          : 'Junte-se a mais de 2.000 leitores. Toda terça: reviews, ofertas e tutoriais de IA. Grátis.'}
      </p>

      <!-- Beehiiv embed form — replace the src with your Beehiiv publication embed URL -->
      <iframe
        src="https://embeds.beehiiv.com/YOUR_BEEHIIV_EMBED_ID"
        data-test-id="beehiiv-embed"
        width="100%"
        height="52"
        frameborder="0"
        scrolling="no"
        style="border-radius: 8px; overflow: hidden; margin: 0; background: transparent;"
      ></iframe>

      <p class="text-xs text-gray-600 mt-4">
        {isEN ? 'No spam. Unsubscribe anytime.' : 'Sem spam. Cancele quando quiser.'}
      </p>
    </div>
  </div>
</section>
