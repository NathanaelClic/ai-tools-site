---
interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;
const isEN = lang === 'en';
const base = isEN ? '' : '/pt';
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="border-b border-white/5 backdrop-blur-xl" style="background:rgba(5,5,10,0.85);">
    <nav class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">

      <a href={isEN ? '/' : '/pt'} class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg bg-violet-600 flex items-center justify-center text-sm font-bold shadow-lg group-hover:shadow-violet-500/50 transition-all" style="box-shadow:0 0 16px rgba(124,58,237,0.4);">⚡</div>
        <span class="font-bold text-white text-sm tracking-tight">AI Tools <span class="text-violet-400">Weekly</span></span>
      </a>

      <div class="hidden md:flex items-center gap-1 text-sm">
        {[
          { href: `${base}/reviews`, label: 'Reviews' },
          { href: `${base}/compare`, label: isEN ? 'Compare' : 'Comparar' },
          { href: `${base}/blog`,    label: 'Blog' },
        ].map(link => (
          <a href={link.href} class="text-gray-400 hover:text-white px-3 py-1.5 rounded-lg transition-all" style="hover:background:rgba(255,255,255,0.05);">
            {link.label}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-2">
        <a href={isEN ? '/pt' : '/'} class="text-xs text-gray-500 hover:text-gray-300 transition-colors border px-3 py-1.5 rounded-lg" style="border-color:rgba(255,255,255,0.1);">
          {isEN ? '🇧🇷 PT' : '🇺🇸 EN'}
        </a>
        <a href="#newsletter" class="btn-primary text-xs py-2 px-4">
          {isEN ? '📬 Newsletter' : '📬 Newsletter'}
        </a>
      </div>
    </nav>
  </div>
</header>
