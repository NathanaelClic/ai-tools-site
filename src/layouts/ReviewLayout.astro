---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

interface Props {
  title: string;
  description: string;
  lang?: string;
  tool: {
    name: string;
    emoji: string;
    tagline: string;
    rating: number;
    pros: string[];
    cons: string[];
    price: string;
    bestFor: string;
    affiliateUrl: string;
    category: string;
  };
}

const { title, description, lang = 'en', tool } = Astro.props;
const isEN = lang === 'en';

const stars = Array.from({ length: 5 }, (_, i) => i < Math.round(tool.rating));
---

<Layout title={title} description={description} lang={lang}>
  <Navbar lang={lang} />

  <main class="pt-28 pb-16 px-4">
    <div class="max-w-3xl mx-auto">

      <!-- Breadcrumb -->
      <nav class="text-xs text-gray-500 mb-8 flex items-center gap-2">
        <a href={isEN ? '/' : '/pt'} class="hover:text-white transition-colors">{isEN ? 'Home' : 'Início'}</a>
        <span>›</span>
        <a href={isEN ? '/reviews' : '/pt/reviews'} class="hover:text-white transition-colors">Reviews</a>
        <span>›</span>
        <span class="text-gray-300">{tool.name}</span>
      </nav>

      <!-- Header -->
      <div class="mb-10">
        <div class="flex items-center gap-4 mb-4">
          <span class="text-5xl">{tool.emoji}</span>
          <div>
            <span class="text-xs font-semibold text-violet-400 uppercase tracking-wider">{tool.category}</span>
            <h1 class="text-3xl md:text-4xl font-bold text-white">{tool.name} {isEN ? 'Review' : '— Review'} 2025</h1>
          </div>
        </div>
        <p class="text-lg text-gray-400">{tool.tagline}</p>
      </div>

      <!-- Rating Box -->
      <div class="card mb-10 flex flex-col md:flex-row gap-6 items-start md:items-center justify-between">
        <div>
          <p class="text-sm text-gray-400 mb-1">{isEN ? 'Our Rating' : 'Nossa Avaliação'}</p>
          <div class="flex items-center gap-2">
            <div class="flex gap-0.5">
              {stars.map((filled) => (
                <span class={filled ? 'text-yellow-400 text-xl' : 'text-gray-700 text-xl'}>★</span>
              ))}
            </div>
            <span class="text-2xl font-bold text-white">{tool.rating}</span>
            <span class="text-gray-500 text-sm">/5</span>
          </div>
        </div>
        <div class="text-sm text-gray-400">
          <p class="mb-1"><span class="text-white font-semibold">{isEN ? 'Best for:' : 'Melhor para:'}</span> {tool.bestFor}</p>
          <p><span class="text-white font-semibold">{isEN ? 'Price:' : 'Preço:'}</span> {tool.price}</p>
        </div>
        <a href={tool.affiliateUrl} target="_blank" rel="noopener noreferrer sponsored" class="btn-primary whitespace-nowrap">
          {isEN ? `Try ${tool.name} →` : `Testar ${tool.name} →`}
        </a>
      </div>

      <!-- Pros & Cons -->
      <div class="grid md:grid-cols-2 gap-6 mb-10">
        <div class="card">
          <h3 class="font-bold text-emerald-400 mb-4 flex items-center gap-2">
            <span>✅</span> {isEN ? 'Pros' : 'Prós'}
          </h3>
          <ul class="space-y-2">
            {tool.pros.map((p) => (
              <li class="text-sm text-gray-300 flex items-start gap-2">
                <span class="text-emerald-400 mt-0.5 shrink-0">+</span> {p}
              </li>
            ))}
          </ul>
        </div>
        <div class="card">
          <h3 class="font-bold text-rose-400 mb-4 flex items-center gap-2">
            <span>❌</span> {isEN ? 'Cons' : 'Contras'}
          </h3>
          <ul class="space-y-2">
            {tool.cons.map((c) => (
              <li class="text-sm text-gray-300 flex items-start gap-2">
                <span class="text-rose-400 mt-0.5 shrink-0">−</span> {c}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Main Content -->
      <article class="prose prose-invert prose-lg max-w-none
        prose-headings:text-white prose-headings:font-bold
        prose-p:text-gray-400 prose-p:leading-relaxed
        prose-a:text-violet-400 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-white prose-li:text-gray-400
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-6 prose-h3:mb-3">
        <slot />
      </article>

      <!-- Bottom CTA -->
      <div class="mt-12 card text-center">
        <p class="text-white font-bold text-xl mb-2">
          {isEN ? `Ready to try ${tool.name}?` : `Pronto para testar o ${tool.name}?`}
        </p>
        <p class="text-gray-400 text-sm mb-6">
          {isEN
            ? 'Click below to get started. Affiliate link — we earn a small commission at no extra cost to you.'
            : 'Clique abaixo para começar. Link de afiliado — ganhamos uma pequena comissão sem custo extra para você.'}
        </p>
        <a href={tool.affiliateUrl} target="_blank" rel="noopener noreferrer sponsored" class="btn-primary">
          {isEN ? `Get ${tool.name} Now →` : `Acessar ${tool.name} Agora →`}
        </a>
      </div>
    </div>
  </main>

  <NewsletterForm lang={lang} />
  <Footer lang={lang} />
</Layout>
