---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const tools = [
  {
    name: 'Jasper AI',
    slug: 'jasper-ai',
    description: 'A ferramenta de escrita com IA mais usada por profissionais de marketing. Cria posts, anúncios e emails em segundos.',
    category: 'Redação',
    rating: 4.8,
    badge: 'Escolha do Editor',
    badgeColor: 'bg-violet-600',
    emoji: '✍️',
    price: 'A partir de $49/mês',
  },
  {
    name: 'Surfer SEO',
    slug: 'surfer-seo',
    description: 'Ferramenta de SEO com IA que ajuda a escrever conteúdo que ranqueia no Google. Usada por mais de 150.000 times.',
    category: 'SEO',
    rating: 4.7,
    badge: 'Melhor para SEO',
    badgeColor: 'bg-emerald-600',
    emoji: '🏄',
    price: 'A partir de $89/mês',
  },
  {
    name: 'Copy.ai',
    slug: 'copy-ai',
    description: 'Crie copies de marketing, descrições de produtos e posts para redes sociais com IA. Plano grátis disponível.',
    category: 'Copywriting',
    rating: 4.6,
    badge: 'Melhor Comissão',
    badgeColor: 'bg-orange-600',
    emoji: '📝',
    price: 'Grátis / A partir de $36/mês',
  },
  {
    name: 'Writesonic',
    slug: 'writesonic',
    description: 'Escritor de IA, chatbot e ferramenta de SEO em um só. Cria artigos longos, landing pages e muito mais.',
    category: 'Redação',
    rating: 4.5,
    badge: 'Melhor Custo-Benefício',
    badgeColor: 'bg-blue-600',
    emoji: '🚀',
    price: 'A partir de $16/mês',
  },
  {
    name: 'Claude AI',
    slug: 'claude-ai',
    description: 'O assistente de IA mais confiável para raciocínio complexo, programação e criação de conteúdo extenso.',
    category: 'Assistente IA',
    rating: 4.9,
    badge: 'Melhor Avaliado',
    badgeColor: 'bg-rose-600',
    emoji: '🤖',
    price: 'Grátis / $20/mês Pro',
  },
  {
    name: 'SEMrush',
    slug: 'semrush',
    description: 'Plataforma completa de marketing com recursos de IA para SEO, anúncios, conteúdo e análise de concorrentes.',
    category: 'Marketing',
    rating: 4.7,
    badge: 'Alto Ticket',
    badgeColor: 'bg-yellow-600',
    emoji: '📊',
    price: 'A partir de $139/mês',
  },
];

const comparisons = [
  { title: 'Jasper AI vs Copy.ai', slug: 'jasper-vs-copy-ai', desc: 'Qual escritor de IA vale o seu dinheiro em 2025?' },
  { title: 'ChatGPT vs Claude', slug: 'chatgpt-vs-claude', desc: 'Os dois assistentes de IA mais poderosos comparados.' },
  { title: 'Surfer SEO vs SEMrush', slug: 'surfer-seo-vs-semrush', desc: 'Qual ferramenta de SEO entrega melhores resultados?' },
];
---

<Layout
  title="AI Tools Weekly — Melhores Ferramentas de IA: Reviews e Comparações 2025"
  description="Reviews honestas e aprofundadas das melhores ferramentas de IA para escrita, SEO, marketing e produtividade. Atualizado semanalmente."
  lang="pt"
>
  <Navbar lang="pt" />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-4 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-violet-950/30 to-transparent pointer-events-none"></div>
    <div class="absolute top-20 left-1/2 -translate-x-1/2 w-96 h-96 bg-violet-600/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-4xl mx-auto relative">
      <span class="inline-block text-xs font-semibold bg-violet-600/20 text-violet-300 border border-violet-500/30 px-4 py-1.5 rounded-full mb-6">
        ⚡ Atualizado semanalmente — 2025
      </span>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
        Descubra as <span class="text-violet-400">Melhores Ferramentas de IA</span><br />Antes de Todo Mundo
      </h1>
      <p class="text-lg text-gray-400 mb-10 max-w-2xl mx-auto">
        Reviews honestas, comparações lado a lado e as melhores picks da semana — ferramentas de IA que realmente economizam tempo e crescem seu negócio.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#ferramentas" class="btn-primary">Explorar Ferramentas</a>
        <a href="#newsletter" class="btn-secondary">Receber Picks Semanais Grátis →</a>
      </div>
      <div class="mt-12 flex flex-wrap justify-center gap-6 text-sm text-gray-500">
        <span>✅ Sem rankings patrocinados</span>
        <span>✅ Testado por usuários reais</span>
        <span>✅ Atualizado toda semana</span>
      </div>
    </div>
  </section>

  <!-- Top Tools Grid -->
  <section id="ferramentas" class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-3">Top Ferramentas de IA de 2025</h2>
        <p class="text-gray-400">Selecionadas e testadas. Ordenadas por valor e confiabilidade.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {tools.map((tool) => (
          <a href={`/pt/reviews/${tool.slug}`} class="card group cursor-pointer block no-underline">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-3xl">{tool.emoji}</span>
                <div>
                  <h3 class="font-bold text-white group-hover:text-violet-400 transition-colors">{tool.name}</h3>
                  <span class="text-xs text-gray-500">{tool.category}</span>
                </div>
              </div>
              <span class={`text-xs text-white font-semibold px-2 py-1 rounded-full ${tool.badgeColor}`}>
                {tool.badge}
              </span>
            </div>
            <p class="text-gray-400 text-sm mb-4 leading-relaxed">{tool.description}</p>
            <div class="flex items-center justify-between text-xs pt-4 border-t border-gray-800">
              <span class="text-yellow-400 font-semibold">★ {tool.rating}/5</span>
              <span class="text-gray-500">{tool.price}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/pt/reviews" class="btn-secondary">Ver Todas as Reviews →</a>
      </div>
    </div>
  </section>

  <!-- Comparisons -->
  <section class="py-16 px-4 bg-gray-900/40">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-3">Comparações Diretas</h2>
        <p class="text-gray-400">Não sabe qual ferramenta escolher? A gente fez o trabalho por você.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {comparisons.map((c) => (
          <a href={`/pt/compare/${c.slug}`} class="card group block text-center no-underline">
            <span class="text-3xl mb-3 block">⚔️</span>
            <h3 class="font-bold text-white group-hover:text-violet-400 transition-colors mb-2">{c.title}</h3>
            <p class="text-gray-400 text-sm">{c.desc}</p>
            <span class="inline-block mt-4 text-violet-400 text-sm">Ver comparação →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Trust Us -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-12">Por que confiar no AI Tools Weekly?</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { icon: '🔬', title: 'Testado na Prática', desc: 'Cada ferramenta é testada por usuários reais antes de publicarmos a review.' },
          { icon: '💰', title: 'Transparência Total', desc: 'Sim, ganhamos comissões. Mas ranqueamos por qualidade primeiro — sempre.' },
          { icon: '🔄', title: 'Atualização Semanal', desc: 'Ferramentas de IA mudam rápido. Atualizamos as reviews toda semana.' },
        ].map((item) => (
          <div class="card text-center">
            <span class="text-4xl mb-4 block">{item.icon}</span>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-gray-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <NewsletterForm lang="pt" />
  <Footer lang="pt" />
</Layout>
