---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

const tools = [
  {
    name: 'Jasper AI',
    slug: 'jasper-ai',
    description: 'The #1 AI writing tool for marketers. Creates blog posts, ads, and email copy in seconds.',
    category: 'Writing',
    rating: 4.8,
    commission: '30% recurring',
    badge: "Editor's Choice",
    badgeColor: 'bg-violet-600',
    emoji: '✍️',
    price: 'From $49/mo',
  },
  {
    name: 'Surfer SEO',
    slug: 'surfer-seo',
    description: 'AI-powered SEO tool that helps you write content that ranks on Google. Used by 150,000+ teams.',
    category: 'SEO',
    rating: 4.7,
    commission: '25% recurring',
    badge: 'Best for SEO',
    badgeColor: 'bg-emerald-600',
    emoji: '🏄',
    price: 'From $89/mo',
  },
  {
    name: 'Copy.ai',
    slug: 'copy-ai',
    description: 'Generate marketing copy, product descriptions, and social posts with AI. Free plan available.',
    category: 'Copywriting',
    rating: 4.6,
    commission: '45% recurring',
    badge: 'Best Commission',
    badgeColor: 'bg-orange-600',
    emoji: '📝',
    price: 'Free / From $36/mo',
  },
  {
    name: 'Writesonic',
    slug: 'writesonic',
    description: 'AI writer, chatbot, and SEO tool in one. Creates long-form articles, landing pages and more.',
    category: 'Writing',
    rating: 4.5,
    commission: '30% recurring',
    badge: 'Great Value',
    badgeColor: 'bg-blue-600',
    emoji: '🚀',
    price: 'From $16/mo',
  },
  {
    name: 'Claude AI',
    slug: 'claude-ai',
    description: 'The most reliable AI assistant for complex reasoning, coding, and long-form content creation.',
    category: 'AI Assistant',
    rating: 4.9,
    commission: 'Via Amazon',
    badge: 'Top Rated',
    badgeColor: 'bg-rose-600',
    emoji: '🤖',
    price: 'Free / $20/mo Pro',
  },
  {
    name: 'SEMrush',
    slug: 'semrush',
    description: 'All-in-one marketing platform with AI features for SEO, PPC, content, and competitor research.',
    category: 'Marketing',
    rating: 4.7,
    commission: '$200 per sale',
    badge: 'High Ticket',
    badgeColor: 'bg-yellow-600',
    emoji: '📊',
    price: 'From $139/mo',
  },
];

const comparisons = [
  { title: 'Jasper AI vs Copy.ai', slug: 'jasper-vs-copy-ai', desc: 'Which AI writer is worth your money in 2025?' },
  { title: 'ChatGPT vs Claude', slug: 'chatgpt-vs-claude', desc: 'The two most powerful AI assistants compared.' },
  { title: 'Surfer SEO vs SEMrush', slug: 'surfer-seo-vs-semrush', desc: 'Which SEO tool gives better results?' },
];
---

<Layout
  title="AI Tools Weekly — Best AI Tool Reviews & Comparisons 2025"
  description="Honest, in-depth reviews of the best AI tools for writing, SEO, marketing, and productivity. Updated weekly."
  lang="en"
>
  <Navbar lang="en" />

  <!-- Hero -->
  <section class="pt-32 pb-20 px-4 text-center relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-violet-950/30 to-transparent pointer-events-none"></div>
    <div class="absolute top-20 left-1/2 -translate-x-1/2 w-96 h-96 bg-violet-600/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="max-w-4xl mx-auto relative">
      <span class="inline-block text-xs font-semibold bg-violet-600/20 text-violet-300 border border-violet-500/30 px-4 py-1.5 rounded-full mb-6">
        ⚡ Updated weekly — 2025
      </span>
      <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
        Find the <span class="text-violet-400">Best AI Tools</span><br />Before Everyone Else
      </h1>
      <p class="text-lg text-gray-400 mb-10 max-w-2xl mx-auto">
        Honest reviews, side-by-side comparisons, and weekly picks of the AI tools that actually save time and grow your business.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#tools" class="btn-primary">Explore Top Tools</a>
        <a href="#newsletter" class="btn-secondary">Get Weekly Picks Free →</a>
      </div>
      <div class="mt-12 flex flex-wrap justify-center gap-6 text-sm text-gray-500">
        <span>✅ No sponsored rankings</span>
        <span>✅ Tested by real users</span>
        <span>✅ Updated every week</span>
      </div>
    </div>
  </section>

  <!-- Top Tools Grid -->
  <section id="tools" class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-3">Top AI Tools of 2025</h2>
        <p class="text-gray-400">Hand-picked and tested. Sorted by value and reliability.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {tools.map((tool) => (
          <a href={`/reviews/${tool.slug}`} class="card group cursor-pointer block no-underline">
            <div class="flex items-start justify-between mb-4">
              <div class="flex items-center gap-3">
                <span class="text-3xl">{tool.emoji}</span>
                <div>
                  <h3 class="font-bold text-white group-hover:text-violet-400 transition-colors">{tool.name}</h3>
                  <span class="text-xs text-gray-500">{tool.category}</span>
                </div>
              </div>
              <span class={`text-xs text-white font-semibold px-2 py-1 rounded-full ${tool.badgeColor}`}>
                {tool.badge}
              </span>
            </div>
            <p class="text-gray-400 text-sm mb-4 leading-relaxed">{tool.description}</p>
            <div class="flex items-center justify-between text-xs pt-4 border-t border-gray-800">
              <span class="text-yellow-400 font-semibold">★ {tool.rating}/5</span>
              <span class="text-gray-500">{tool.price}</span>
              <span class="text-emerald-400">{tool.commission}</span>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/reviews" class="btn-secondary">View All Reviews →</a>
      </div>
    </div>
  </section>

  <!-- Comparisons -->
  <section class="py-16 px-4 bg-gray-900/40">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-3">Head-to-Head Comparisons</h2>
        <p class="text-gray-400">Not sure which tool to choose? We did the work for you.</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {comparisons.map((c) => (
          <a href={`/compare/${c.slug}`} class="card group block text-center no-underline">
            <span class="text-3xl mb-3 block">⚔️</span>
            <h3 class="font-bold text-white group-hover:text-violet-400 transition-colors mb-2">{c.title}</h3>
            <p class="text-gray-400 text-sm">{c.desc}</p>
            <span class="inline-block mt-4 text-violet-400 text-sm">Read comparison →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Trust Us -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-white mb-12">Why Trust AI Tools Weekly?</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {[
          { icon: '🔬', title: 'Hands-On Testing', desc: 'Every tool is tested by real users before we publish a review. No copy-paste specs.' },
          { icon: '💰', title: 'Affiliate Transparency', desc: 'Yes, we earn commissions. But we rank tools by quality first — always.' },
          { icon: '🔄', title: 'Weekly Updates', desc: 'AI tools change fast. We update reviews every week to keep you ahead.' },
        ].map((item) => (
          <div class="card text-center">
            <span class="text-4xl mb-4 block">{item.icon}</span>
            <h3 class="font-bold text-white mb-2">{item.title}</h3>
            <p class="text-gray-400 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <NewsletterForm lang="en" />
  <Footer lang="en" />
</Layout>
