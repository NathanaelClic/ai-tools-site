---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const comparisons = [
  { title: 'Jasper AI vs Copy.ai', slug: 'jasper-vs-copy-ai', desc: 'Which AI writer is worth your money in 2025?', emoji: '⚔️' },
  { title: 'ChatGPT vs Claude', slug: 'chatgpt-vs-claude', desc: 'The two most powerful AI assistants compared head-to-head.', emoji: '🥊' },
  { title: 'Surfer SEO vs SEMrush', slug: 'surfer-seo-vs-semrush', desc: 'Which SEO platform delivers better results for content teams?', emoji: '📊' },
];
---

<Layout
  title="AI Tool Comparisons 2025 — Side-by-Side Reviews | AI Tools Weekly"
  description="Compare the best AI tools head to head. Honest, data-driven comparisons to help you choose the right tool for your needs."
  lang="en"
>
  <Navbar lang="en" />
  <main class="pt-28 pb-16 px-4">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <h1 class="text-4xl font-bold text-white mb-4">AI Tool Comparisons</h1>
        <p class="text-gray-400">Can't decide between two tools? We put them head to head so you don't have to.</p>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {comparisons.map((c) => (
          <a href={`/compare/${c.slug}`} class="card group block no-underline">
            <span class="text-3xl mb-3 block">{c.emoji}</span>
            <h2 class="font-bold text-white group-hover:text-violet-400 transition-colors mb-2 text-lg">{c.title}</h2>
            <p class="text-gray-400 text-sm mb-4">{c.desc}</p>
            <span class="text-violet-400 text-sm">Read comparison →</span>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer lang="en" />
</Layout>
